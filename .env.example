# Public Supabase project — server + browser both read these.
# Legacy VITE_* names still work as a fallback during migration.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Pokemon TCG API key — only used client-side for search.
NEXT_PUBLIC_POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key
